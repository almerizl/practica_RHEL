PRACTICA 3: Alta Disponibilidad Web con Keepalived
=======================================================================

Comandos usados en la Máquina 1
============================================
# Personalizar la página web del Servidor 1 en los Virtual Hosts:
echo "<h1>Bienvenidos a: Server 1</h1>" > /var/www/html/sitio80/index.html

# Dentro crear la misma configuracion en el puerto 8080:
echo "<h1>Bienvenidos a: Server 1</h1>" > /var/www/html/sitio8080/index.html

# Reiniciar Apache para aplicar el cambio de página web:
systemctl restart httpd

# Inyectar la configuración limpia de Keepalived en modo MASTER con prioridad 100:
echo -e "global_defs {\n    router_id nodo1\n}\n\nvrrp_instance VI_1 {\n    state MASTER\n    interface ens160\n    virtual_router_id 51\n    priority 100\n    advert_int 1\n    authentication {\n        auth_type PASS\n        auth_pass 1234\n    }\n    virtual_ipaddress {\n        192.168.124.180/24\n    }\n}" > /etc/keepalived/keepalived.conf

# Habilitar e iniciar el servicio Keepalived:
systemctl enable --now keepalived

# Verificar que el servicio esté activo y comprobar la IP flotante:
systemctl status keepalived


Comandos usados en la Máquina 2
============================================
# Personalizar la página web del Servidor 2 en los Virtual Hosts:
echo "<h1>Bienvenidos a: Server 2</h1>" > /var/www/html/sitio80/index.html

# Dentro crear la misma configuracion en el puerto 8080:
echo "<h1>Bienvenidos a: Server 2</h1>" > /var/www/html/sitio8080/index.html

# Reiniciar Apache para aplicar el cambio de página web:
systemctl restart httpd

# Inyectar la configuración limpia de Keepalived en modo BACKUP con prioridad 90:
echo -e "global_defs {\n    router_id nodo2\n}\n\nvrrp_instance VI_1 {\n    state BACKUP\n    interface ens192\n    virtual_router_id 51\n    priority 90\n    advert_int 1\n    authentication {\n        auth_type PASS\n        auth_pass 1234\n    }\n    virtual_ipaddress {\n        192.168.124.180/24\n    }\n}" > /etc/keepalived/keepalived.conf

# Habilitar e iniciar el servicio Keepalived:
systemctl enable --now keepalived

# Verificar el estado correcto del servicio de respaldo:
systemctl status keepalived
