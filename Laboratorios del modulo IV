PRACTICA 1: Instalar un servidor HTTP apache2/nginx
=======================================================================

Comandos usados practica 1
============================================
# Instalación del servidor web Apache (httpd) en RHEL 10:
sudo mount /dev/cdrom /mnt/disc
dnf install httpd -y

# Creación de los directorios para ambos sitios web:
mkdir -p /var/www/html/puerto80
mkdir -p /var/www/html/puerto8080

# Creación del website estático para el puerto 80 ("Hola Mundo"):
echo "<h1>Hola Mundo</h1>" | sudo tee /var/www/html/puerto80/index.html

# Creación del website estático para el puerto 8080 (Datos personales):
echo "<h1>Nombre: Cris Almeris Zanellato Lorenzo</h1><h2>Matricula: 2025-2285</h2><h3>Materia: Sistemas Operativos 3</h3>" | sudo tee /var/www/html/puerto8080/index.html

# Configuración de los Hosts Virtuales y escucha de puertos:
# (Editar archivo /etc/httpd/conf/httpd.conf y asegurar las siguientes líneas)
# Listen 80
# Listen 8080

# Creación del archivo de configuración para los Virtual Hosts:
# Archivo: /etc/httpd/conf.d/vhosts.conf
#
# <VirtualHost *:80>
#     DocumentRoot "/var/www/html/puerto80"
# </VirtualHost>
#
# <VirtualHost *:8080>
#     DocumentRoot "/var/www/html/puerto8080"
# </VirtualHost>

# Configuración de permisos en el Firewall para ambos puertos:
firewall-cmd --zone=public --add-port=80/tcp --permanent
firewall-cmd --zone=public --add-port=8080/tcp --permanent
firewall-cmd --reload

# Habilitar y arrancar el servicio de Apache:
systemctl enable --now httpd

